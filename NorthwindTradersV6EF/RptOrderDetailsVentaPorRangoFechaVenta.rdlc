                          <KeepTogether>true</KeepTogether>
                          <Paragraphs>
                            <Paragraph>
                              <TextRuns>
                                <TextRun>
                                  <Value>=IIF(
   Len("[" &amp; Fields!ProductID.Value.ToString() &amp; "]" &amp; Fields!ProductName.Value) &gt; (Parameters!MaxLength.Value + 3),
   Left("[" &amp; Fields!ProductID.Value.ToString() &amp; "]" &amp; Fields!ProductName.Value, Parameters!MaxLength.Value) &amp; "...",
   "[" &amp; Fields!ProductID.Value.ToString() &amp; "]" &amp; Fields!ProductName.Value
)</Value>
                                  <Style>
                                    <FontFamily>Consolas</FontFamily>
                                    <FontSize>5pt</FontSize>
